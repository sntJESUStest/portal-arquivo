{
  "functions": {
    "api/dropbox-webhook.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/send-notification.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/check-guias.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/send-email.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/check-guias",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/funcionario", "destination": "/index.html" },
    { "source": "/empresas", "destination": "/index.html" },
    { "source": "/set-password.html", "destination": "/set-password.html" },
    { "source": "/((?!set-password\\.html).*)", "destination": "/index.html" }
  ]
}
